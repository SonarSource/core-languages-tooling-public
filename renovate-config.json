{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Shared Renovate preset for SonarSource product-development repositories.",
  "extends": ["local>SonarSource/renovate-config"],
  "minimumReleaseAge": "5 days",
  "minimumReleaseAgeBehaviour": "timestamp-optional",
  "rebaseWhen": "never",
  "enabledManagers": [
    "github-actions",
    "maven",
    "nuget",
    "gradle",
    "gradle-wrapper",
    "npm",
    "cargo",
    "pre-commit",
    "mise",
    "custom.regex"
  ],
  "packageRules": [
    {
      "description": "Don't group updates by default",
      "matchPackageNames": ["*"],
      "groupName": null
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": false
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["pin", "rollback"],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^snapshot-generation\\.sh$"],
      "matchStrings": [
        "datasource=(?<datasource>.*?) depName=(?<depName>.*?)\\sexport .*?_VERSION=(?<currentValue>.*)\\s"
      ],
      "versioningTemplate": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(?:\\.(?<build>\\d+))?$"
    }
  ]
}
